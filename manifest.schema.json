{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://draftmyvan.dev/schemas/manifest.schema.json",
  "title": "DraftMyVan Module Manifest",
  "description": "Single source of truth for a placeable module (cabinet, bed, etc.). Millimetres are canonical; every downstream tool (UE5, Blender, Fusion 360) reads dimensions from here.",
  "type": "object",
  "required": [
    "version",
    "id",
    "type",
    "dimensions_mm",
    "anchor",
    "placement",
    "clearances",
    "visual",
    "manufacturing",
    "rules"
  ],
  "additionalProperties": false,
  "properties": {
    "version": {
      "description": "Schema version this entry conforms to. Bump when fields are added/removed.",
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "id": {
      "description": "Stable, lowercase, underscore-separated unique identifier.",
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_]*$",
      "minLength": 3,
      "maxLength": 64
    },
    "type": {
      "description": "Top-level category. Drives placement and validation rules.",
      "type": "string",
      "enum": ["cabinet", "bed", "seating", "appliance", "tank", "panel", "accessory"]
    },
    "dimensions_mm": {
      "description": "External bounding box in millimetres. Integers only — no fractional mm in the manifest.",
      "type": "object",
      "required": ["width", "depth", "height"],
      "additionalProperties": false,
      "properties": {
        "width":  { "type": "integer", "minimum": 1, "maximum": 6000 },
        "depth":  { "type": "integer", "minimum": 1, "maximum": 3000 },
        "height": { "type": "integer", "minimum": 1, "maximum": 3000 }
      }
    },
    "anchor": {
      "description": "Local origin used when snapping into the van. All clearances and placement are measured from here.",
      "type": "string",
      "enum": [
        "floor_back_left",
        "floor_back_right",
        "floor_front_left",
        "floor_front_right",
        "ceiling_back_left",
        "ceiling_back_right",
        "wall_left_back",
        "wall_right_back"
      ]
    },
    "placement": {
      "description": "Which surface the module attaches to.",
      "type": "string",
      "enum": ["floor", "wall", "ceiling", "freestanding"]
    },
    "clearances": {
      "description": "Required empty space around the module, in millimetres. Soft warnings if violated (per philosophy).",
      "type": "object",
      "required": ["front_mm", "sides_mm", "above_mm"],
      "additionalProperties": false,
      "properties": {
        "front_mm": { "type": "integer", "minimum": 0, "maximum": 2000 },
        "sides_mm": { "type": "integer", "minimum": 0, "maximum": 2000 },
        "above_mm": { "type": "integer", "minimum": 0, "maximum": 2000 }
      }
    },
    "visual": {
      "description": "Visual asset references consumed by UE5 (via Blender exports).",
      "type": "object",
      "required": ["glb_path", "collision_proxy", "material_slots"],
      "additionalProperties": false,
      "properties": {
        "glb_path": {
          "type": "string",
          "pattern": "^assets/.+\\.glb$"
        },
        "collision_proxy": {
          "description": "Name of the UCX_ prefixed collision mesh inside the GLB.",
          "type": "string",
          "pattern": "^UCX_[a-z0-9_]+$"
        },
        "material_slots": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          }
        }
      }
    },
    "manufacturing": {
      "description": "Inputs the Fusion 360 brain uses to produce cut lists, DXFs, and assembly docs.",
      "type": "object",
      "required": [
        "fusion_template",
        "plywood_thickness_mm",
        "weight_kg",
        "hardware"
      ],
      "additionalProperties": false,
      "properties": {
        "fusion_template": {
          "description": "Identifier of the parametric Fusion 360 template that regenerates this part family.",
          "type": "string",
          "pattern": "^[a-z0-9_]+$"
        },
        "plywood_thickness_mm": {
          "type": "number",
          "enum": [12, 15, 18, 21, 24]
        },
        "weight_kg": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 500
        },
        "hardware": {
          "description": "Hardware line items consumed during assembly.",
          "type": "array",
          "minItems": 0,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9_]+(_[0-9]+x)?$"
          }
        }
      }
    },
    "rules": {
      "description": "Buildability metadata. Soft signals for UX warnings and catalog filtering.",
      "type": "object",
      "required": ["cnc_eligible", "build_difficulty", "service_access"],
      "additionalProperties": false,
      "properties": {
        "cnc_eligible": { "type": "boolean" },
        "build_difficulty": {
          "type": "string",
          "enum": ["easy", "medium", "hard"]
        },
        "service_access": {
          "type": "array",
          "minItems": 0,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["front_panel", "back_panel", "left_panel", "right_panel", "top_panel", "bottom_panel"]
          }
        }
      }
    }
  }
}
